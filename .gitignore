# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/

# build output at root level (prevent accidental root pollution)
# NOTE: /out/ is NOT ignored — build artifacts must be committed for deployment
/index.html
/404.html
/sw.js
/manifest.json
/_next/
/_not-found/
/__next.*.txt

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# .env.local is committed intentionally (contains only public NEXT_PUBLIC_ anon keys)
.env*.local
!.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Service account credentials (NEVER commit!)
scripts/service-account.json
supabase/.temp/
.claude/
